{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "baseUrl": "src",
    "paths": {
      // Portfolio paths
      "@/components/*": [
        "components/*"
      ],
      "@/views/*": [
        "views/*"
      ],
      "@/layouts/*": [
        "layouts/*"
      ],
      // EPL paths
      "@/epl/components/*": [
        "sports/epl/components/*"
      ],
      "@/epl/views/*": [
        "sports/epl/views/*"
      ],
      "@/epl/layouts/*": [
        "sports/epl/layouts/*"
      ],
      // Global paths
      "@/assets/*": [
        "assets/*"
      ],
      "@/api/*": [
        "api/*"
      ],
      "@/lib/*": [
        "lib/*"
      ],
      "@/types/*": [
        "types/*"
      ],
      "@/hooks/*": [
        "hooks/*"
      ],
      "@/utils/*": [
        "utils/*"
      ],
      "@/worldcup/*": [
        "sports/worldcup/*"
      ],
      "@/shared/*": [
        "shared/*"
      ],
      "@/ncaa-male/*": [
        "sports/ncaa-male/*"
      ],
      "@/female/*": [
        "sports/female/*"
      ]
    },
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src"
  ]
}